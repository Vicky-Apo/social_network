# Server
SERVER_HOST=localhost
SERVER_ADDR=:8080
DEBUG=true

# Database
DATABASE_PATH=file:./data/social.db
MIGRATIONS_PATH=pkg/db/migrations/sqlite
MAX_OPEN_CONNS=1    ### with 1 we avoid "database is locked" errors ,race conditions , write conflicts
MAX_IDLE_CONNS=1    ### with 1 we keep the connections to the minimum needed
