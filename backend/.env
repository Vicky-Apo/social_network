# Server
SERVER_HOST=localhost
SERVER_ADDR=:8080
DEBUG=true

# Database
DATABASE_URL=postgres://social-network-role:123456@localhost:5433/social-network-db?sslmode=disable
MIGRATIONS_PATH=pkg/db/migrations/postgres
MAX_OPEN_CONNS=10
MAX_IDLE_CONNS=5

# Authentication
BCRYPT_COST=12
SESSION_TOKEN_BYTES=32
SESSION_DURATION_DAYS=30
SESSION_COOKIE_NAME=session_token
MIN_PASSWORD_LENGTH=8
MIN_USER_AGE=13

POSTGRES_USER=social-network-role
POSTGRES_PASSWORD=123456
POSTGRES_DB=social-network-db

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=10000

# CORS
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# Security Headers
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP=default-src 'self'
SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()
SECURITY_HSTS=max-age=31536000; includeSubDomains