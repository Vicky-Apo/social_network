          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"author_id\": {{authorId}},\n  \"content\": \"{{commentContent}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}/comments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts",
